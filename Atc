<script>
/* ── CURSOR ──────────────────────────────────────────────── */
const dot = document.getElementById('cd');
const ring = document.getElementById('cr');
if(dot && ring && window.matchMedia('(pointer:fine)').matches){
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{
    mx=e.clientX; my=e.clientY;
    dot.style.left=mx+'px'; dot.style.top=my+'px';
  });
  (function loop(){
    rx+=(mx-rx)*.11; ry+=(my-ry)*.11;
    ring.style.left=rx+'px'; ring.style.top=ry+'px';
    requestAnimationFrame(loop);
  })();
  document.querySelectorAll('a,button,.svc-cell,.portal,.testi-card,.team-card').forEach(el=>{
    el.addEventListener('mouseenter',()=>document.body.classList.add('cursor-hover'));
    el.addEventListener('mouseleave',()=>document.body.classList.remove('cursor-hover'));
  });
}

/* ── NAV PIN ─────────────────────────────────────────────── */
const nav = document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('pinned',scrollY>60),{passive:true});

/* ── MOBILE MENU ──────────────────────────────────────────── */
document.getElementById('navHamburger').onclick = ()=>document.getElementById('mobileMenu').classList.add('open');
document.getElementById('mobileClose').onclick = closeMobile;
function closeMobile(){ document.getElementById('mobileMenu').classList.remove('open'); }

/* ── HERO CANVAS ─────────────────────────────────────────── */
(function(){
  const c = document.getElementById('hero-canvas');
  const g = c.getContext('2d');
  let W,H,pts=[];

  function resize(){
    W = c.width  = c.offsetWidth;
    H = c.height = c.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize, {passive:true});

  // build particles
  function makeParticle(){
    return {
      x: Math.random()*W, y: Math.random()*H,
      r: Math.random()*1.2+.25,
      vx:(Math.random()-.5)*.25,
      vy:(Math.random()-.5)*.25,
      a: Math.random()*.45+.05,
      gold: Math.random()>.55
    };
  }
  for(let i=0;i<140;i++) pts.push(makeParticle());

  let t=0;
  function frame(){
    g.clearRect(0,0,W,H);

    // deep base
    g.fillStyle='#020609';
    g.fillRect(0,0,W,H);

    // aurora glows
    t+=.004;
    const glows=[
      {cx:.18+Math.sin(t)*.25,    cy:.28+Math.cos(t*.8)*.18,  r:.55, c:'rgba(201,168,76,.065)'},
      {cx:.72+Math.cos(t*.6)*.2,  cy:.55+Math.sin(t*.9)*.15,  r:.5,  c:'rgba(26,170,150,.05)'},
      {cx:.45+Math.sin(t*1.3)*.18,cy:.75+Math.cos(t*1.1)*.12, r:.45, c:'rgba(201,168,76,.04)'},
    ];
    glows.forEach(gl=>{
      const grd=g.createRadialGradient(W*gl.cx,H*gl.cy,0,W*gl.cx,H*gl.cy,W*gl.r);
      grd.addColorStop(0,gl.c); grd.addColorStop(1,'transparent');
      g.fillStyle=grd; g.fillRect(0,0,W,H);
    });

    // vignette left (text readability)
    const v=g.createLinearGradient(0,0,W*.7,0);
    v.addColorStop(0,'rgba(2,6,9,.45)'); v.addColorStop(1,'transparent');
    g.fillStyle=v; g.fillRect(0,0,W,H);

    // bottom fade
    const bf=g.createLinearGradient(0,H*.55,0,H);
    bf.addColorStop(0,'transparent'); bf.addColorStop(1,'#020609');
    g.fillStyle=bf; g.fillRect(0,0,W,H);

    // particles
    pts.forEach(p=>{
      p.x+=p.vx; p.y+=p.vy;
      if(p.x<-2||p.x>W+2||p.y<-2||p.y>H+2){
        p.x=Math.random()*W; p.y=Math.random()*H;
      }
      g.beginPath();
      g.arc(p.x,p.y,p.r,0,Math.PI*2);
      g.fillStyle=p.gold ? `rgba(201,168,76,${p.a})` : `rgba(26,170,150,${p.a*.7})`;
      g.fill();
    });

    // subtle grid lines
    g.strokeStyle='rgba(201,168,76,.028)'; g.lineWidth=1;
    for(let x=0;x<W;x+=120){g.beginPath();g.moveTo(x,0);g.lineTo(x,H);g.stroke();}
    for(let y=0;y<H;y+=120){g.beginPath();g.moveTo(0,y);g.lineTo(W,y);g.stroke();}

    requestAnimationFrame(frame);
  }
  frame();
})();

/* ── COUNTERS ─────────────────────────────────────────────── */
function runCounter(el, target, suffix, dur){
  let start=null;
  function step(ts){
    if(!start) start=ts;
    const p=Math.min((ts-start)/dur,1);
    const eased=1-Math.pow(1-p,3);
    el.textContent=Math.round(eased*target)+suffix;
    if(p<1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
setTimeout(()=>{
  runCounter(document.getElementById('sn1'),50,'+',1800);
  runCounter(document.getElementById('sn2'),12,'+',1600);
  runCounter(document.getElementById('sn3'),98,'%',2000);
},1000);

/* ── SCROLL REVEAL ─────────────────────────────────────────── */
const revEls = document.querySelectorAll('.rv,.rv-l,.rv-r');
const ro = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('on'); ro.unobserve(e.target); } });
},{threshold:.1,rootMargin:'0px 0px -50px 0px'});
revEls.forEach(el=>ro.observe(el));

/* ── FORM SUBMIT ───────────────────────────────────────────── */
function submitForm(e){
  e.preventDefault();
  const btn=document.getElementById('cfBtn');
  btn.textContent='✓ Message Sent';
  btn.style.background='var(--teal)';
  btn.style.color='#fff';
  btn.disabled=true;
  setTimeout(()=>{
    btn.textContent='Send Message';
    btn.style.background='';
    btn.style.color='';
    btn.disabled=false;
    e.target.reset();
  },4000);
}

/* ── ACTIVE NAV LINKS ──────────────────────────────────────── */
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let cur='';
  sections.forEach(s=>{
    if(scrollY>=s.offsetTop-120) cur=s.id;
  });
  navLinks.forEach(a=>{
    a.style.color = a.getAttribute('href')==='#'+cur ? 'var(--gold)' : '';
  });
},{passive:true});
</script>
