<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Achieve Together Care — NDIS Registered Provider delivering person-centred disability support across Melbourne, VIC.">
<meta property="og:title" content="Achieve Together Care — NDIS Provider Melbourne">
<meta property="og:description" content="Empowering lives through genuine, person-centred disability support.">
<title>Achieve Together Care — NDIS Provider Melbourne</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..500;9..600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ─── RESET & ROOT ─────────────────────────────────────────── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; font-size:16px; }
img { display:block; max-width:100%; }
a { text-decoration:none; color:inherit; }

:root {
  --gold:       #c9a84c;
  --gold-lt:    #e8c570;
  --gold-dk:    #a07c30;
  --gold-10:    rgba(201,168,76,.10);
  --gold-20:    rgba(201,168,76,.20);
  --teal:       #1aaa96;
  --teal-10:    rgba(26,170,150,.10);
  --ink:        #020609;
  --ink-1:      #070e18;
  --ink-2:      #0c1828;
  --ink-3:      #112038;
  --cream:      #f4ede0;
  --cream-60:   rgba(244,237,224,.60);
  --cream-35:   rgba(244,237,224,.35);
  --cream-15:   rgba(244,237,224,.15);
  --border:     rgba(201,168,76,.16);
  --border-hi:  rgba(201,168,76,.40);
  --font-disp:  'Cormorant Garamond', Georgia, serif;
  --font-body:  'DM Sans', sans-serif;
  --font-mono:  'Space Mono', monospace;
  --ease-out:   cubic-bezier(.22,1,.36,1);
  --ease-in:    cubic-bezier(.64,0,.78,0);
}

body {
  background: var(--ink);
  color: var(--cream);
  font-family: var(--font-body);
  font-weight: 300;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ─── CURSOR ─────────────────────────────────────────────────── */
.cursor-dot, .cursor-ring {
  position: fixed; top:0; left:0;
  border-radius: 50%; pointer-events: none;
  z-index: 9999; transform: translate(-50%,-50%);
  will-change: transform;
  transition: width .25s var(--ease-out), height .25s var(--ease-out), background .25s, border-color .25s;
}
.cursor-dot  { width:8px; height:8px; background: var(--gold); }
.cursor-ring { width:40px; height:40px; border:1px solid var(--gold-20); }
body.cursor-hover .cursor-dot  { width:16px; height:16px; background: var(--gold-lt); }
body.cursor-hover .cursor-ring { width:56px; height:56px; border-color: var(--gold); }
@media(pointer:coarse){ .cursor-dot,.cursor-ring{ display:none; } }

/* ─── SCROLLBAR ──────────────────────────────────────────────── */
::-webkit-scrollbar { width:3px; }
::-webkit-scrollbar-track { background: var(--ink); }
::-webkit-scrollbar-thumb { background: var(--gold); }

/* ─── NOISE TEXTURE OVERLAY ──────────────────────────────────── */
body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:999;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  background-size: 200px;
  opacity: .5;
}

/* ─── NAV ────────────────────────────────────────────────────── */
#nav {
  position: fixed; top:0; left:0; right:0; z-index:500;
  padding: 1.8rem 5vw;
  display: flex; align-items:center; justify-content:space-between;
  transition: padding .5s var(--ease-out), background .5s, border-color .5s;
  border-bottom: 1px solid transparent;
}
#nav.pinned {
  padding: 1rem 5vw;
  background: rgba(2,6,9,.88);
  backdrop-filter: blur(28px) saturate(1.4);
  border-color: var(--border);
}
.nav-brand { display:flex; flex-direction:column; gap:2px; }
.nav-brand-name {
  font-family: var(--font-disp);
  font-size: 1.25rem; font-weight:600; letter-spacing:.02em;
  line-height:1;
}
.nav-brand-name em { color:var(--gold); font-style:normal; }
.nav-brand-sub {
  font-size:.6rem; font-weight:500; letter-spacing:.24em; text-transform:uppercase;
  color:var(--gold);
}
.nav-links {
  display:flex; align-items:center; gap:2.5rem; list-style:none;
}
.nav-links a {
  font-size:.75rem; font-weight:500; letter-spacing:.12em; text-transform:uppercase;
  color:var(--cream-60);
  position:relative; padding-bottom:3px;
  transition: color .3s;
}
.nav-links a::after {
  content:''; position:absolute; bottom:0; left:0;
  width:0; height:1px; background:var(--gold);
  transition: width .35s var(--ease-out);
}
.nav-links a:hover { color:var(--gold); }
.nav-links a:hover::after { width:100%; }
.nav-cta {
  border:1px solid var(--border-hi) !important;
  padding:.55rem 1.4rem !important; color:var(--gold) !important;
  transition: background .3s, color .3s !important;
}
.nav-cta:hover { background:var(--gold) !important; color:var(--ink) !important; }
.nav-cta::after { display:none !important; }
.nav-hamburger {
  display:none; flex-direction:column; gap:5px;
  background:none; border:none; cursor:none; padding:4px;
}
.nav-hamburger span {
  display:block; width:24px; height:1px; background:var(--cream);
  transition: transform .3s, opacity .3s;
}
.mobile-menu {
  display:none; position:fixed; inset:0; top:0;
  background: rgba(2,6,9,.97); backdrop-filter:blur(20px);
  z-index:499; flex-direction:column; align-items:center; justify-content:center;
  gap:2rem;
}
.mobile-menu.open { display:flex; }
.mobile-menu a {
  font-family: var(--font-disp); font-size:2.5rem; font-weight:300;
  color:var(--cream); transition: color .3s;
}
.mobile-menu a:hover { color:var(--gold); }
.mobile-close {
  position:absolute; top:2rem; right:5vw;
  background:none; border:none; color:var(--cream);
  font-size:1.5rem; cursor:none;
}

/* ─── HERO ───────────────────────────────────────────────────── */
#hero {
  position:relative; min-height:100vh;
  display:flex; align-items:center;
  overflow:hidden;
}
#hero-canvas {
  position:absolute; inset:0; width:100%; height:100%;
}
.hero-inner {
  position:relative; z-index:2;
  display:grid; grid-template-columns:1fr auto;
  align-items:center; gap:4rem;
  padding: 0 5vw; width:100%; margin-top:5rem;
}
.hero-copy { max-width:760px; }
.hero-eyebrow {
  display:inline-flex; align-items:center; gap:.8rem;
  margin-bottom:2.4rem;
  opacity:0; transform:translateY(16px);
  animation: fadeUp .8s .2s var(--ease-out) forwards;
}
.hero-eyebrow-bar { width:36px; height:1px; background:var(--gold); }
.hero-eyebrow-txt {
  font-size:.65rem; font-weight:600; letter-spacing:.26em; text-transform:uppercase;
  color:var(--gold);
}
.hero-h1 {
  font-family: var(--font-disp);
  font-size: clamp(3.8rem,8.5vw,7.5rem);
  font-weight:300; line-height:1.0;
  opacity:0; transform:translateY(30px);
  animation: fadeUp 1.1s .4s var(--ease-out) forwards;
}
.hero-h1 span { display:block; }
.hero-h1 .italic { font-style:italic; color:var(--gold); }
.hero-desc {
  max-width:520px;
  font-size:1.05rem; line-height:1.9; color:var(--cream-60);
  margin:2.2rem 0 3rem;
  opacity:0; transform:translateY(20px);
  animation: fadeUp .9s .65s var(--ease-out) forwards;
}
.hero-btns {
  display:flex; align-items:center; flex-wrap:wrap; gap:1.5rem;
  opacity:0; transform:translateY(20px);
  animation: fadeUp .9s .85s var(--ease-out) forwards;
}
.btn-gold {
  display:inline-flex; align-items:center; gap:.75rem;
  background:var(--gold); color:var(--ink);
  padding:.95rem 2.4rem;
  font-size:.75rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
  position:relative; overflow:hidden;
  transition: transform .3s var(--ease-out), box-shadow .3s;
}
.btn-gold::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.22),transparent);
  transform:translateX(-100%); transition: transform .55s var(--ease-out);
}
.btn-gold:hover { transform:translateY(-3px); box-shadow:0 24px 64px rgba(201,168,76,.35); }
.btn-gold:hover::before { transform:translateX(100%); }
.btn-ghost {
  display:inline-flex; align-items:center; gap:.6rem;
  font-size:.75rem; font-weight:500; letter-spacing:.1em; text-transform:uppercase;
  color:var(--cream-60); transition: color .3s; padding:.95rem 0;
}
.btn-ghost svg { transition: transform .3s var(--ease-out); }
.btn-ghost:hover { color:var(--cream); }
.btn-ghost:hover svg { transform:translateX(5px); }

/* Orbiting NDIS badge */
.hero-badge {
  flex-shrink:0;
  opacity:0; transform:scale(.85);
  animation: popIn .9s 1.2s var(--ease-out) forwards;
}
.badge-ring {
  position:relative; width:180px; height:180px;
}
.badge-ring svg.spin {
  position:absolute; inset:0; width:100%; height:100%;
  animation: spinRing 20s linear infinite;
}
.badge-inner {
  position:absolute; inset:16px;
  border-radius:50%;
  background: rgba(2,6,9,.7);
  backdrop-filter:blur(12px);
  border:1px solid var(--border-hi);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:2px;
}
.badge-label { font-size:.55rem; letter-spacing:.22em; text-transform:uppercase; color:var(--gold); }
.badge-big { font-family:var(--font-disp); font-size:2rem; font-weight:600; color:var(--cream); line-height:1; }
.badge-sub  { font-size:.52rem; letter-spacing:.14em; text-transform:uppercase; color:var(--cream-35); }

/* Hero stats */
.hero-stats {
  position:absolute; bottom:3.5rem; left:5vw; right:5vw; z-index:2;
  display:flex; align-items:center; gap:0; flex-wrap:wrap;
  opacity:0; animation: fadeUp .8s 1.1s var(--ease-out) forwards;
}
.hero-stat {
  flex:1; min-width:130px;
  padding:1.4rem 2rem;
  border-right:1px solid var(--border);
  border-top:1px solid var(--border);
}
.hero-stat:last-child { border-right:none; }
.stat-num {
  font-family:var(--font-disp);
  font-size:2.6rem; font-weight:300; color:var(--gold); line-height:1;
}
.stat-label {
  font-size:.62rem; font-weight:500; letter-spacing:.18em; text-transform:uppercase;
  color:var(--cream-35); margin-top:4px;
}

/* scroll cue */
.hero-scroll {
  position:absolute; bottom:3.5rem; left:50%; transform:translateX(-50%);
  display:flex; flex-direction:column; align-items:center; gap:.5rem;
  z-index:2; opacity:0; animation: fadeUp .7s 1.6s var(--ease-out) forwards;
}
.hero-scroll span { font-size:.55rem; letter-spacing:.24em; text-transform:uppercase; color:var(--cream-35); }
.hero-scroll-line {
  width:1px; height:52px;
  background:linear-gradient(var(--gold), transparent);
  animation:scrollBob 2.2s ease-in-out infinite;
}

/* ─── MARQUEE ────────────────────────────────────────────────── */
.marquee-wrap {
  overflow:hidden; background:var(--gold);
  padding:.75rem 0;
  border-top:1px solid var(--gold-dk); border-bottom:1px solid var(--gold-dk);
}
.marquee-track {
  display:inline-flex; gap:0; white-space:nowrap;
  animation: marquee 28s linear infinite;
}
.marquee-track span {
  display:inline-flex; align-items:center; gap:2.5rem;
  padding:0 2.5rem;
  font-size:.68rem; font-weight:700; letter-spacing:.22em; text-transform:uppercase;
  color:var(--ink);
}
.marquee-track span::before {
  content:'✦'; font-size:.5rem; opacity:.5;
}

/* ─── SECTION UTILITIES ──────────────────────────────────────── */
.s-pad { padding:8rem 5vw; }
.s-pad-sm { padding:6rem 5vw; }
.section-eye {
  display:inline-flex; align-items:center; gap:.8rem; margin-bottom:1.4rem;
}
.section-eye-bar { width:28px; height:1px; background:var(--gold); }
.section-eye-txt {
  font-size:.62rem; font-weight:600; letter-spacing:.24em; text-transform:uppercase; color:var(--gold);
}
.section-h2 {
  font-family:var(--font-disp);
  font-size: clamp(2.2rem,5vw,4rem);
  font-weight:300; line-height:1.08;
}
.section-h2 strong { font-weight:600; font-style:italic; }
.section-h2 em { color:var(--gold); font-style:italic; font-weight:300; }

/* reveal */
.rv { opacity:0; transform:translateY(44px); transition:opacity .9s var(--ease-out), transform .9s var(--ease-out); }
.rv.on { opacity:1; transform:translateY(0); }
.rv-l { opacity:0; transform:translateX(-44px); transition:opacity .9s var(--ease-out), transform .9s var(--ease-out); }
.rv-l.on { opacity:1; transform:translateX(0); }
.rv-r { opacity:0; transform:translateX(44px); transition:opacity .9s var(--ease-out), transform .9s var(--ease-out); }
.rv-r.on { opacity:1; transform:translateX(0); }

/* ─── SERVICES ───────────────────────────────────────────────── */
#services { background:var(--ink-1); }
.services-head {
  display:grid; grid-template-columns:1fr 1fr; gap:3rem;
  align-items:end; margin-bottom:4rem;
}
.services-head-desc { color:var(--cream-60); line-height:1.85; font-size:.95rem; }
.svc-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  border:1px solid var(--border);
}
.svc-cell {
  padding:2.8rem 2.2rem 2.5rem;
  border-right:1px solid var(--border);
  border-bottom:1px solid var(--border);
  position:relative; overflow:hidden;
  transition:background .45s, transform .35s var(--ease-out);
  display:block; color:inherit;
}
.svc-cell:nth-child(3n){ border-right:none; }
.svc-cell:nth-last-child(-n+3){ border-bottom:none; }
.svc-cell::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, var(--gold-10) 0%, transparent 55%);
  opacity:0; transition:opacity .45s;
}
.svc-cell:hover { background:var(--ink-2); }
.svc-cell:hover::before { opacity:1; }
.svc-n {
  font-family:var(--font-mono); font-size:.6rem; color:var(--gold);
  opacity:.5; margin-bottom:1.6rem; letter-spacing:.08em;
}
.svc-icon {
  font-size:1.5rem; margin-bottom:1.4rem; display:block;
  transform:translateY(0); transition:transform .3s var(--ease-out);
}
.svc-cell:hover .svc-icon { transform:translateY(-4px); }
.svc-title {
  font-family:var(--font-disp); font-size:1.55rem; font-weight:400;
  color:var(--cream); margin-bottom:.9rem; line-height:1.15;
}
.svc-desc { font-size:.84rem; line-height:1.85; color:var(--cream-35); }
.svc-arrow {
  position:absolute; bottom:2.2rem; right:2.2rem;
  width:32px; height:32px; border-radius:50%;
  border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  color:var(--gold); font-size:.7rem;
  opacity:0; transform:translate(6px,6px) scale(.8);
  transition:all .35s var(--ease-out);
}
.svc-cell:hover .svc-arrow { opacity:1; transform:translate(0,0) scale(1); border-color:var(--gold); }

/* ─── ABOUT ──────────────────────────────────────────────────── */
#about { display:grid; grid-template-columns:1fr 1fr; gap:8vw; align-items:center; }
.about-img-wrap { position:relative; }
.about-img-inner {
  position:relative; overflow:hidden;
  aspect-ratio:4/5;
}
.about-img-inner img {
  width:100%; height:100%; object-fit:cover; object-position:top center;
  filter:contrast(1.06) saturate(.9);
  transition:transform .8s var(--ease-out);
}
.about-img-wrap:hover .about-img-inner img { transform:scale(1.04); }
.about-frame {
  position:absolute; inset:-14px; z-index:-1;
  border:1px solid var(--border);
  pointer-events:none;
}
.about-badge {
  position:absolute; bottom:-1.5rem; right:-1.5rem;
  background:var(--gold); padding:1.4rem 1.6rem; z-index:2;
  text-align:center;
}
.about-badge-n {
  font-family:var(--font-disp); font-size:2.2rem; font-weight:700;
  color:var(--ink); line-height:1;
}
.about-badge-l {
  font-size:.6rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
  color:var(--ink); margin-top:3px;
}
.about-body { color:var(--cream-60); line-height:1.9; font-size:.95rem; margin:2rem 0 2.5rem; }
.about-list { list-style:none; display:flex; flex-direction:column; gap:.8rem; margin-bottom:3rem; }
.about-list li {
  display:flex; align-items:center; gap:1rem;
  font-size:.84rem; color:var(--cream-60);
}
.about-list li::before { content:''; width:18px; height:1px; background:var(--gold); flex-shrink:0; }
.cert-row {
  display:flex; gap:1.5rem; flex-wrap:wrap; margin-top:3.5rem;
}
.cert-pill {
  display:inline-flex; align-items:center; gap:.6rem;
  border:1px solid var(--border);
  padding:.5rem 1rem;
  font-size:.65rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase;
  color:var(--cream-60);
}
.cert-pill-dot { width:6px; height:6px; border-radius:50%; background:var(--gold); }

/* ─── PORTALS ────────────────────────────────────────────────── */
#portals { background:var(--ink-1); }
.portals-head { text-align:center; max-width:620px; margin:0 auto 5rem; }
.portals-head .section-h2 { margin-bottom:1rem; }
.portals-head p { color:var(--cream-60); line-height:1.85; }
.portals-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.portal {
  background:var(--ink-2);
  border:1px solid var(--border);
  padding:3rem 2.5rem;
  position:relative; overflow:hidden;
  transition:transform .4s var(--ease-out), border-color .4s, box-shadow .4s;
}
.portal::after {
  content:''; position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg,var(--gold),var(--teal));
  transform:scaleX(0); transform-origin:left;
  transition:transform .5s var(--ease-out);
}
.portal:hover { transform:translateY(-10px); border-color:var(--border-hi); box-shadow:0 40px 80px rgba(0,0,0,.5); }
.portal:hover::after { transform:scaleX(1); }
.portal-badge {
  display:inline-block; margin-bottom:1.4rem;
  font-size:.58rem; font-weight:600; letter-spacing:.22em; text-transform:uppercase;
  color:var(--gold);
  border:1px solid var(--border); padding:.3rem .8rem;
}
.portal-title {
  font-family:var(--font-disp); font-size:2rem; font-weight:400;
  color:var(--cream); line-height:1.05; margin-bottom:1.8rem;
}
.portal-list { list-style:none; display:flex; flex-direction:column; gap:.7rem; margin-bottom:2.5rem; }
.portal-list li {
  font-size:.82rem; color:var(--cream-35); line-height:1.5;
  padding-left:1rem; position:relative;
}
.portal-list li::before {
  content:''; position:absolute; left:0; top:.6em;
  width:4px; height:4px; border-radius:50%; background:var(--gold);
}
.portal-link {
  display:inline-flex; align-items:center; gap:.6rem;
  font-size:.72rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase;
  color:var(--gold); transition:gap .3s;
}
.portal-link:hover { gap:1rem; }
.portal-link svg { transition:transform .3s var(--ease-out); }
.portal-link:hover svg { transform:translateX(3px); }

/* ─── TRANSPORT ──────────────────────────────────────────────── */
#transport {
  display:grid; grid-template-columns:1fr 1fr; gap:8vw; align-items:center;
}
.transport-nums {
  display:grid; grid-template-columns:1fr 1fr; gap:1px;
  background:var(--border); border:1px solid var(--border); margin-bottom:3rem;
}
.transport-num-cell {
  background:var(--ink); padding:2rem;
}
.transport-num-val {
  font-family:var(--font-disp); font-size:2.5rem; font-weight:300; color:var(--gold);
  line-height:1;
}
.transport-num-label {
  font-size:.62rem; font-weight:500; letter-spacing:.16em; text-transform:uppercase;
  color:var(--cream-35); margin-top:5px;
}
.transport-img {
  position:relative; aspect-ratio:4/3; overflow:hidden;
}
.transport-img img { width:100%; height:100%; object-fit:cover; }
.transport-img::before {
  content:''; position:absolute; inset:0; z-index:1;
  background:linear-gradient(135deg, var(--gold-10) 0%, transparent 50%);
}

/* ─── TEAM ───────────────────────────────────────────────────── */
#team { background:var(--ink-1); }
.team-head {
  display:grid; grid-template-columns:1fr 1fr; align-items:end; gap:3rem;
  margin-bottom:4rem;
}
.team-head-note { color:var(--cream-60); line-height:1.85; font-size:.95rem; }
.team-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; }
.team-card { overflow:hidden; }
.team-photo {
