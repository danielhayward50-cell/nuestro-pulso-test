  filter:grayscale(35%) contrast(1.05);
  transition:transform .7s var(--ease-out), filter .7s;
}
.team-card:hover .team-photo img { transform:scale(1.06); filter:grayscale(0%) contrast(1.05); }
.team-photo-overlay {
  position:absolute; inset:0; z-index:1;
  background:linear-gradient(to top, rgba(2,6,9,.92) 0%, transparent 50%);
  display:flex; align-items:flex-end; padding:1.4rem;
}
.team-photo-name {
  font-family:var(--font-disp); font-size:1.3rem; font-weight:400; color:var(--cream);
}
.team-photo-role {
  font-size:.58rem; font-weight:600; letter-spacing:.2em; text-transform:uppercase;
  color:var(--gold); margin-bottom:.25rem;
}
.team-tags {
  display:flex; flex-wrap:wrap; gap:.35rem; padding:.9rem 0 0;
}
.tag {
  font-size:.58rem; font-weight:500; letter-spacing:.08em;
  padding:.22rem .65rem; border:1px solid var(--border);
  color:var(--cream-35); border-radius:20px;
}

/* ─── TESTIMONIALS ───────────────────────────────────────────── */
#testimonials { }
.testimonials-head { text-align:center; max-width:600px; margin:0 auto 5rem; }
.testi-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.testi-card {
  background:var(--ink-1); border:1px solid var(--border);
  padding:2.8rem; position:relative; overflow:hidden;
  transition:border-color .4s, transform .4s var(--ease-out);
}
.testi-card:hover { border-color:var(--border-hi); transform:translateY(-6px); }
.testi-quote-mark {
  font-family:var(--font-disp); font-size:6rem; line-height:.6;
  color:var(--gold); opacity:.15; position:absolute; top:1.5rem; left:1.8rem;
  pointer-events:none; user-select:none;
}
.testi-text {
  font-size:.9rem; line-height:1.9; color:var(--cream-60);
  position:relative; z-index:1; padding-top:1rem; margin-bottom:2rem;
}
.testi-author { display:flex; align-items:center; gap:1rem; }
.testi-av {
  width:42px; height:42px; border-radius:50%; flex-shrink:0;
  background:var(--gold);
  display:flex; align-items:center; justify-content:center;
  font-family:var(--font-disp); font-size:1.1rem; font-weight:600; color:var(--ink);
}
.testi-name { font-size:.85rem; font-weight:500; color:var(--cream); }
.testi-role { font-size:.7rem; color:var(--cream-35); margin-top:2px; }

/* ─── CONTACT ────────────────────────────────────────────────── */
#contact { background:var(--ink-1); display:grid; grid-template-columns:1fr 1fr; gap:8vw; align-items:start; }
.contact-detail-list { margin-top:2.5rem; }
.contact-detail {
  display:flex; align-items:flex-start; gap:1.4rem;
  padding:1.4rem 0; border-bottom:1px solid var(--border);
}
.contact-detail:first-child { border-top:1px solid var(--border); }
.contact-d-icon {
  width:38px; height:38px; flex-shrink:0; border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  font-size:.9rem;
  transition:border-color .3s, background .3s;
}
.contact-detail:hover .contact-d-icon { border-color:var(--gold); background:var(--gold-10); }
.contact-d-label {
  font-size:.6rem; font-weight:600; letter-spacing:.2em; text-transform:uppercase;
  color:var(--gold); margin-bottom:.25rem;
}
.contact-d-val { font-size:.92rem; color:var(--cream); }
/* Form */
.cf { }
.cf-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.cf-field { margin-bottom:1.2rem; }
.cf-field label {
  display:block; font-size:.6rem; font-weight:600; letter-spacing:.2em; text-transform:uppercase;
  color:var(--gold); margin-bottom:.5rem;
}
.cf-field input,
.cf-field textarea,
.cf-field select {
  width:100%; background:var(--ink-2); border:1px solid var(--border);
  color:var(--cream); padding:.85rem 1rem;
  font-family:var(--font-body); font-size:.9rem; font-weight:300;
  outline:none; border-radius:0; resize:none;
  transition:border-color .3s;
  appearance:none;
}
.cf-field input:focus,
.cf-field textarea:focus,
.cf-field select:focus { border-color:var(--gold); }
.cf-field select { background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0l5 6 5-6z' fill='%23c9a84c'/%3E%3C/svg%3E"); background-repeat:no-repeat; background-position:right 1rem center; }
.cf-field option { background:var(--ink-2); }
.cf-submit {
  width:100%; background:var(--gold); border:none;
  color:var(--ink); padding:1rem;
  font-family:var(--font-body); font-size:.78rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase;
  cursor:none; transition:opacity .3s, transform .2s;
  position:relative; overflow:hidden;
}
.cf-submit::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);
  transform:translateX(-100%); transition:transform .5s var(--ease-out);
}
.cf-submit:hover { opacity:.92; transform:translateY(-2px); }
.cf-submit:hover::before { transform:translateX(100%); }
.cf-submit:active { transform:translateY(0); }
.cf-note { font-size:.7rem; color:var(--cream-35); text-align:center; margin-top:.8rem; }
.abn-chip {
  display:inline-flex; align-items:center; gap:.5rem; margin-top:3rem;
  font-family:var(--font-mono); font-size:.62rem;
  color:var(--gold); border:1px solid var(--border); padding:.3rem .9rem;
}

/* ─── FOOTER ─────────────────────────────────────────────────── */
footer {
  background:var(--ink); border-top:1px solid var(--border);
  padding:5rem 5vw 2.5rem;
}
.foot-top { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:4rem; margin-bottom:4rem; }
.foot-brand-n { font-family:var(--font-disp); font-size:1.5rem; font-weight:600; }
.foot-brand-n em { color:var(--gold); font-style:normal; }
.foot-brand-tag { font-size:.6rem; font-weight:600; letter-spacing:.22em; text-transform:uppercase; color:var(--gold); margin:4px 0 1rem; }
.foot-brand-body { font-size:.83rem; line-height:1.8; color:var(--cream-35); max-width:260px; }
.foot-col-h { font-size:.62rem; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:var(--cream); margin-bottom:1.4rem; }
.foot-links { list-style:none; display:flex; flex-direction:column; gap:.7rem; }
.foot-links a { font-size:.83rem; color:var(--cream-35); transition:color .3s; }
.foot-links a:hover { color:var(--gold); }
.foot-divider { border:none; border-top:1px solid var(--border); margin-bottom:2rem; }
.foot-bottom { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; }
.foot-copy { font-size:.72rem; color:var(--cream-35); }
.foot-legal { display:flex; gap:2rem; }
.foot-legal a { font-size:.72rem; color:var(--cream-35); transition:color .3s; }
.foot-legal a:hover { color:var(--gold); }

/* ─── ANIMATIONS ─────────────────────────────────────────────── */
@keyframes fadeUp {
  to { opacity:1; transform:translateY(0); }
}
@keyframes popIn {
  to { opacity:1; transform:scale(1); }
}
@keyframes marquee {
  from { transform:translateX(0); }
  to   { transform:translateX(-50%); }
}
@keyframes spinRing {
  to { transform:rotate(360deg); }
}
@keyframes scrollBob {
  0%,100% { opacity:1; transform:scaleY(1); transform-origin:top; }
  60%      { opacity:.25; transform:scaleY(.6); }
}
@keyframes pulse {
  0%,100% { opacity:1; }
  50%      { opacity:.4; }
}

/* ─── RESPONSIVE ─────────────────────────────────────────────── */
@media(max-width:1100px){
  .hero-inner { grid-template-columns:1fr; }
  .hero-badge { display:none; }
